
{% if section.blocks.size > 0 %}
  <script
    src="{{ 'announcement-bar.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endif %}

{% render 'contrast-override', background_color: section.settings.background_color, section_id: section.id %}

<div class="section-background color-custom-{{ section.id }}"></div>
<aside
  class="announcement-bar spacing-style section section--{{ section.settings.section_width }} color-custom-{{ section.id }}"
  style="{% render 'spacing-padding', settings: section.settings %}; --border-bottom-width: {{ section.settings.divider_width }}px;{% if section.settings.divider_color != blank %} --color-border: {{ section.settings.divider_color }};{% endif %}"
>
  <announcement-bar-component class="announcement-bar__marquee">
    <div class="announcement-bar__track">
      <div class="announcement-bar__content">
        {% for block in section.blocks %}
          {% assign block_settings = block.settings %}
          <span class="announcement-bar__item">
            <span class="announcement-text">{{ block_settings.text }}</span>
            {% if block_settings.link_text != blank %}
              <span class="announcement-link-text">{{ block_settings.link_text }}</span>
            {% endif %}
            {% if block_settings.link != blank %}
              <a href="{{ block_settings.link }}" class="announcement-bar__item-link">
                <span class="visually-hidden">{{ block_settings.text | strip_html }}</span>
              </a>
            {% endif %}
          </span>
        {% endfor %}
      </div>
      <div class="announcement-bar__content announcement-bar__content--clone">
        {% for block in section.blocks %}
          {% assign block_settings = block.settings %}
          <span class="announcement-bar__item">
            <span class="announcement-text">{{ block_settings.text }}</span>
            {% if block_settings.link_text != blank %}
              <span class="announcement-link-text">{{ block_settings.link_text }}</span>
            {% endif %}
            {% if block_settings.link != blank %}
              <a href="{{ block_settings.link }}" class="announcement-bar__item-link">
                <span class="visually-hidden">{{ block_settings.text | strip_html }}</span>
              </a>
            {% endif %}
          </span>
        {% endfor %}
      </div>
    </div>
  </announcement-bar-component>
</aside>

{% stylesheet %}
  .announcement-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
    overflow: hidden;
    background-color: #1c1d1d;
    color: #fff;
  }

  .announcement-bar__marquee {
    display: flex;
    width: 100%;
    overflow: hidden;
  }

  .announcement-bar__track {
    display: flex;
    white-space: nowrap;
    will-change: transform;
  }

  .announcement-bar__content {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  .announcement-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 1.5rem;
    white-space: nowrap;
    position: relative;
  }

  .announcement-bar__item + .announcement-bar__item:before {
    content: "";
    display: inline-block;
    width: 4px;
    height: 4px;
    background: currentColor;
    border-radius: 50%;
    margin-right: 1.5rem;
    opacity: 0.5;
  }

  .announcement-bar__item .announcement-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.8;
  }

  .announcement-bar__item .announcement-link-text {
    font-size: 0.8rem;
    font-weight: 500;
  }

  .announcement-bar__item-link {
    position: absolute;
    inset: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "t:settings.scroll_speed",
      "min": 2,
      "max": 10,
      "default": 5,
      "unit": "sec"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "t:settings.divider_color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ section.settings.divider_width > 0 }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
